{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "rulepilot",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "api.openai.com"
      ]
    },
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "triggers": {
    "onPostSubmit": "/internal/triggers/post-submit",
    "onPostDelete": "/internal/triggers/post-delete"
  },
  "settings": {
    "global": {
      "openai-api-key": {
        "type": "string",
        "label": "OpenAI API key",
        "helpText": "Used only when LLM classification is enabled. Store this with devvit settings set.",
        "isSecret": true
      }
    },
    "subreddit": {
      "scan-mode": {
        "type": "select",
        "label": "RulePilot action mode",
        "helpText": "Monitor only logs, flag reports likely issues, filter routes high-confidence issues to mod review.",
        "options": [
          {
            "label": "Filter to mod review",
            "value": "filter"
          },
          {
            "label": "Flag only",
            "value": "flag"
          },
          {
            "label": "Monitor only",
            "value": "monitor"
          }
        ],
        "defaultValue": "filter"
      },
      "llm-enabled": {
        "type": "boolean",
        "label": "Use OpenAI for ambiguous posts",
        "helpText": "When disabled, RulePilot uses deterministic checks only.",
        "defaultValue": true
      },
      "openai-model": {
        "type": "string",
        "label": "OpenAI model",
        "helpText": "Low-cost structured-output model used for ambiguous classification.",
        "defaultValue": "gpt-5-nano"
      },
      "confidence-threshold": {
        "type": "number",
        "label": "Global confidence threshold",
        "helpText": "Minimum confidence before RulePilot takes the configured action.",
        "defaultValue": 0.76
      },
      "timezone": {
        "type": "string",
        "label": "Subreddit timezone",
        "helpText": "Used for day-specific rules like Sunday memes.",
        "defaultValue": "America/Chicago"
      },
      "enabled-rule-ids": {
        "type": "multiSelect",
        "label": "Enabled r/csMajors preset rules",
        "helpText": "Choose which preset rules RulePilot should evaluate.",
        "options": [
          {
            "label": "Out of scope",
            "value": "out-of-scope"
          },
          {
            "label": "Respectful engagement",
            "value": "respectful-engagement"
          },
          {
            "label": "Shitposts and memes",
            "value": "shitposts-and-memes"
          },
          {
            "label": "AMAs, surveys, hiring and referrals",
            "value": "amas-surveys-hiring-referrals"
          },
          {
            "label": "Resume sticky",
            "value": "resume-sticky"
          },
          {
            "label": "Amazon currently optional",
            "value": "amazon-optional"
          },
          {
            "label": "Live OA questions",
            "value": "live-oa-questions"
          },
          {
            "label": "Spam",
            "value": "spam"
          },
          {
            "label": "Lazy or low-quality posts",
            "value": "low-quality"
          },
          {
            "label": "Common questions",
            "value": "common-questions"
          },
          {
            "label": "AI Large Language Models",
            "value": "ai-llms"
          },
          {
            "label": "College comparison posts",
            "value": "college-comparison"
          },
          {
            "label": "Laptop posts",
            "value": "laptop-posts"
          },
          {
            "label": "Restricted posts",
            "value": "restricted-posts"
          },
          {
            "label": "Personal projects",
            "value": "personal-projects"
          }
        ],
        "defaultValue": [
          "out-of-scope",
          "respectful-engagement",
          "shitposts-and-memes",
          "amas-surveys-hiring-referrals",
          "resume-sticky",
          "amazon-optional",
          "live-oa-questions",
          "spam",
          "low-quality",
          "common-questions",
          "ai-llms",
          "college-comparison",
          "laptop-posts",
          "restricted-posts",
          "personal-projects"
        ]
      }
    }
  },
  "menu": {
    "items": [
      {
        "label": "Scan with RulePilot",
        "description": "Run the RulePilot triage classifier on this post",
        "forUserType": "moderator",
        "location": "post",
        "endpoint": "/internal/menu/scan-post"
      },
      {
        "label": "RulePilot: mark correct",
        "description": "Mark the latest RulePilot result for this post as correct",
        "forUserType": "moderator",
        "location": "post",
        "endpoint": "/internal/menu/mark-correct"
      },
      {
        "label": "RulePilot: false positive",
        "description": "Mark the latest RulePilot result for this post as a false positive",
        "forUserType": "moderator",
        "location": "post",
        "endpoint": "/internal/menu/mark-false-positive"
      },
      {
        "label": "Create RulePilot dashboard",
        "description": "Create a moderator dashboard post for this subreddit",
        "forUserType": "moderator",
        "location": "subreddit",
        "endpoint": "/internal/menu/create-dashboard"
      }
    ]
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "rulepilot_dev"
  }
}
