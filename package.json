    "devvit": "0.12.24",
    "hono": "4.11.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@types/node": "25.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.16"
